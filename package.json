{
  "name": "@assert-click/runner",
  "version": "1.0.13",
  "description": "CLI runner for Assert — run Markdown scenarios locally or in CI with Playwright and send results back to Assert",
  "license": "MIT",
  "homepage": "https://assert.click",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pixel-Funnel/assert-runner.git"
  },
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "assert": "bin/assert.js",
    "assert-runner": "bin/assert-runner.js"
  },
  "files": [
    "bin/",
    "src/cli.js",
    "src/config.js",
    "src/executor.js"
  ],
  "dependencies": {
    "@playwright/test": "^1.40.0",
    "dotenv": "^16.0.0",
    "playwright": "^1.40.0"
  },
  "scripts": {
    "postinstall": "node -e \"require('child_process').execSync('npx playwright install chromium --with-deps', { stdio: 'inherit' })\" || true"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "assert",
    "playwright",
    "e2e",
    "testing",
    "cli",
    "test-runner",
    "automation",
    "ci",
    "end-to-end",
    "markdown",
    "ai-testing"
  ]
}
